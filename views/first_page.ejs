<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login / Sign Up</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/script.js"></script>
</head>

<body>

    <% if(typeof message !== "undefined" && message){ %>
    <div class="message-box">
        <%= message %>
    </div>
    <% } %>

<div class="container">

    <!-- ================= LOGIN ================= -->
    <div id="loginForm">
        <h2>Login</h2>

        <form action="/login" method="POST">
            <input type="text" name="name" placeholder="Ex - Ayush" required>
            <input type="email" name="email" placeholder="Email" required>

            <input type="password" name="password" placeholder="Password" required>

            <select name="role" required>
                <option value="">Select Type</option>
                <option value="Employee">Employee</option>
                <option value="Student">Student</option>
                <option value="Admin">Admin</option>
            </select>

            <button type="submit">Login</button>
        </form>

        <div class="toggle">
            <a href="#" onclick="showSignup()">New user? Sign up</a>
        </div>
    </div>

    <!-- ================= SIGNUP ================= -->
    <div id="signupForm" class="hidden">

        <h2>Sign Up</h2>

        <select id="userType" onchange="toggleFields()">
            <option value="">Select Type</option>
            <option value="Student">Student</option>
            <option value="Employee">Employee</option>
            <option value="Admin">Admin</option>
        </select>

        <form action="/signup" method="POST" id="signup" id ="myForm">

            <input type="text" name="name" placeholder="Ex - Ayush" required>

            <input type="email" name="email" placeholder="Email" required>

            <input type="password" id="password" name="password" placeholder="Password" required>

            <input type="password" id="confirmpassword" name="confirmpassword" placeholder="Confirm Password" required>

            <p id="msg" style="font-size:12px; margin:0;"></p>

            <input type="text" name="refno" placeholder="Secret Reference Number" required>

            <div id="employeeField" class="hidden">
                <input type="text" name="department" placeholder="Department">
            </div>

             <div id="adminField" class="hidden">
                <input type="text" name="adminpassword" placeholder="Admin Special Password">
            </div>

            <button type="submit" id = "submitBtn">Sign Up</button>
        </form>

        <div class="toggle">
            <a href="#" onclick="showLogin()">Already have account? Login</a>
        </div>
        <br> <br>
        <b>Note :-</b> 
        <br>
<hr>
<br>
        <!-- ===== NOTE SECTION ===== -->
        <div class="note">
            <p>
                <h3>What is Secret Reference Key?</h3>
            </p>
        </div>

        <!-- Info Section -->
        <div id="info" class="info-box">
    <h3>🔑 Secret Reference Key</h3>
    <p>
        The Secret Reference Key is used to verify authorized users during signup. 
        It ensures that only valid students or employees can register in the system.
        <br><br>
        Using this Secret Reference Key, you can create a new account in the system.
        My Secret Reference Key is => for_test123
    </p>
</div>

         <br> <br>
<hr>

        <!-- Demo Section -->
        <h3>View Demo Credentials</h3>
        <div id="demo" class="info-box">
            <h3>🧪 Demo Login Credentials</h3>

            <p><b>Student:</b></p>
            <ul>
                <li>Name: Ayush</li>
                <li>Email: student@gmail.com</li>
                <li>Password: 12345@student</li>
            </ul>

            <p><b>Employee:</b></p>
            <ul>
                <li>Name: Rahul</li>
                <li>Email: employee@gmail.com</li>
                <li>Password: 12345@employe</li>
            </ul>
           <p><b>You can also create an admin, but it may cause security issues.</b></p>
        </div>

    </div>

</div>

</body>
</html>